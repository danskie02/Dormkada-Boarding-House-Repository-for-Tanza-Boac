# Copy this file to `.env` and fill in values.
# Do NOT commit `.env`.

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# In Supabase:
# Project Settings → Database → Connection string → URI
#
# Recommended for migrations/dev tools (drizzle-kit):
# - Use "Direct connection"
# - Include `?sslmode=require`
#
# Pooler note:
# - If you use the pooler host (*.pooler.supabase.com), the username format is:
#   postgres.<PROJECT_REF>
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
PORT=3001

# -----------------------------------------------------------------------------
# Web (Vite)
# -----------------------------------------------------------------------------
# In dev, Vite proxies `/api` → this URL so the React app can call `/api/...`.
# Override only if your API runs elsewhere.
# API_PROXY_TARGET=http://127.0.0.1:3001

# Production API URL (for Render deployment)
# This is the actual backend API server URL used in production
VITE_API_URL=https://your-api-server.onrender.com

# -----------------------------------------------------------------------------
# Email Service (SendGrid)
# -----------------------------------------------------------------------------
# Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
# From email address (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# Display name for emails
SENDGRID_FROM_NAME=DormKada
# Admin email for notifications (owner verification, pending listings, etc)
ADMIN_EMAIL=admin@example.com