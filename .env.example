# Copy this file to `.env` and fill in values.
# Do NOT commit `.env`.

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# In Supabase:
# Project Settings → Database → Connection string → URI
#
# Recommended for migrations/dev tools (drizzle-kit):
# - Use "Direct connection"
# - Include `?sslmode=require`
#
# Pooler note:
# - If you use the pooler host (*.pooler.supabase.com), the username format is:
#   postgres.<PROJECT_REF>
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
PORT=3001

# -----------------------------------------------------------------------------
# Web (Vite)
# -----------------------------------------------------------------------------
# In dev, Vite proxies `/api` → this URL so the React app can call `/api/...`.
# Override only if your API runs elsewhere.
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

